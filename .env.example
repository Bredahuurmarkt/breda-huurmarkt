# Breda Huurmarkt Monitor - configuratie template
# Kopieer dit bestand naar .env en vul je echte waarden in.
# Het echte .env-bestand komt NOOIT in git (zie .gitignore).

# --- Anthropic Claude API ---
# Haal op via https://console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Model voor de dagelijkse samenvatting
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Gmail API ---
# Het pad naar je OAuth client-credentials (gedownload uit Google Cloud Console).
# Standaard zoeken we naar credentials.json in de projectmap.
GMAIL_CREDENTIALS_FILE=credentials.json
# Hier wordt na de eerste login je toegangstoken bewaard (auto-gegenereerd).
GMAIL_TOKEN_FILE=token.json

# Op welke afzenders/labels filteren we alert-mails?
# Komma-gescheiden lijst van afzenderadressen.
ALERT_SENDERS=noreply@pararius.nl,no-reply@funda.nl,noreply@huurwoningen.nl

# --- Notificatie via Gmail SMTP ---
# Het e-mailadres waar het dagelijks overzicht heen gaat.
NOTIFY_TO=jouw-email@gmail.com
# Afzender (meestal je eigen Gmail).
NOTIFY_FROM=jouw-email@gmail.com
# Gmail App-wachtwoord (NIET je gewone wachtwoord!):
# https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=

# --- Filters Breda ---
STAD=Breda
# Laat leeg voor alle prijzen, of zet bijv. MAX_PRIJS=1500
MIN_PRIJS=
MAX_PRIJS=

# --- Database ---
DATABASE_PATH=data/huurmarkt.db
